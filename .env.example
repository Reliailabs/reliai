APP_ENV=development
APP_NAME=Reliai API
APP_VERSION=0.1.0
APP_URL=http://127.0.0.1:3000
API_URL=http://127.0.0.1:8000
WEB_URL=http://127.0.0.1:3000
DATABASE_URL=postgresql+psycopg://reliai:reliai@localhost:5432/reliai
REDIS_URL=redis://localhost:6379/0
RQ_QUEUE_NAME=default
LOG_LEVEL=INFO
TRACE_WAREHOUSE_URL=
CLICKHOUSE_DATABASE=reliai
EVENT_STREAM_BROKERS=localhost:9092
EVENT_STREAM_TOPIC_TRACES=trace_events
ENABLED_PROCESSORS=evaluation,warehouse,reliability_metrics,regression
API_KEY_HASH_SECRET=change-me
AUTH_SESSION_HASH_SECRET=change-me-session-secret
AUTH_SESSION_DAYS=14
WORKOS_API_KEY=
WORKOS_CLIENT_ID=
WORKOS_REDIRECT_URI=http://127.0.0.1:3000/auth/callback
WORKOS_LOGOUT_REDIRECT_URI=http://127.0.0.1:3000/sign-in
WORKOS_COOKIE_PASSWORD=
WORKOS_SCIM_WEBHOOK_SECRET=
RELIAI_DEV_AUTH_ENABLED=false
# RELIAI_ADMIN_CLI_ENABLED=true
# Usage (run from apps/api): RELIAI_ADMIN_CLI_ENABLED=true python -m reliai.cli admin grant --email owner@company.com
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_TEAM=
STRIPE_PRICE_PRODUCTION=
TRACE_INPUT_TEXT_MAX_CHARS=20000
TRACE_OUTPUT_TEXT_MAX_CHARS=20000
TRACE_METADATA_MAX_BYTES=16384
TEST_DATABASE_ADMIN_URL=postgresql+psycopg://reliai:reliai@localhost:5432/postgres
NEXT_PUBLIC_API_URL=http://127.0.0.1:8000
NEXT_PUBLIC_APP_URL=http://127.0.0.1:3000
NEXT_PUBLIC_WORKOS_REDIRECT_URI=http://127.0.0.1:3000/auth/callback
