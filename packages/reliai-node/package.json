{
  "name": "@reliai/sdk",
  "version": "0.1.0",
  "description": "Reliai SDK for trace ingestion and runtime instrumentation.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://reliai.ai",
  "repository": {
    "type": "git",
    "url": "https://github.com/Reliailabs/reliai"
  },
  "keywords": ["reliai", "observability", "ai", "tracing", "incident"],
  "engines": {
    "node": ">=18"
  },
  "files": ["dist", "README.md"],
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./auto": {
      "types": "./dist/auto.d.ts",
      "default": "./dist/auto.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build && pnpm run typecheck"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.5.0",
    "typescript": "^5.7.3"
  }
}
