{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "API (FastAPI)",
      "runtimeExecutable": "python",
      "runtimeArgs": ["-m", "uvicorn", "app.main:app", "--reload", "--host", "0.0.0.0", "--port", "8000"],
      "port": 8000
    },
    {
      "name": "Web (Next.js)",
      "runtimeExecutable": "/opt/homebrew/bin/node",
      "env": { "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin" },
      "runtimeArgs": ["/opt/homebrew/Cellar/pnpm/10.26.0/libexec/lib/node_modules/pnpm/bin/pnpm.cjs", "--filter", "web", "dev"],
      "port": 3000
    }
  ]
}
